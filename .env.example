# 全局配置
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-flash-2026-04-16

# Embedding配置（二选一）
# 方案 A：本地 Ollama（推荐，免费）
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# 方案 B：在线 API（DashScope/OpenAI 等，注释掉方案 A 后启用）
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_DIM=1024

# PDF处理配置
PDF_TEXT_THRESHOLD=50
OCR_CONFIDENCE_THRESHOLD=0.6

# 分块配置
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# 检索配置
RETRIEVAL_TOP_K=10
KEYWORD_TOP_K=5

# 自检配置
SELF_CHECK_THRESHOLD=0.7

# 多模态模型配置（可选，OCR兜底识别）
# MULTIMODAL_API_KEY=your-multimodal-api-key
# MULTIMODAL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MULTIMODAL_MODEL=qwen-vl-plus
# OCR_FALLBACK_CONFIDENCE_THRESHOLD=0.6

# 业务类型
BUSINESS_TYPE=general

# 扫描目录配置
SCAN_DIR=data
AUTO_SCAN_ON_STARTUP=true
